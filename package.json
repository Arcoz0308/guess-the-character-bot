{
  "name": "guess-the-character-bot",
  "version": "1.0.0",
  "description": "A discord bot made with arcscord",
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "start": "npx prisma generate && node -r @swc-node/register -r tsconfig-paths/register src/index.ts",
    "dev": "npx nodemon --exec node -r @swc-node/register -r tsconfig-paths/register src/index.ts dev debug",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "postinstall": "npx prisma generate",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "arcscord": "0.3.0-beta-9",
    "discord.js": "^14.26.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.16.0",
    "@swc-node/core": "^1.14.1",
    "@swc-node/register": "^1.11.1",
    "@types/node": "^20.19.39",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.14",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
