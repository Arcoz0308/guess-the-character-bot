{
  "name": "guess-the-character-bot",
  "version": "1.0.0",
  "description": "A discord bot made with arcscord",
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "start": "node -r @swc-node/register -r tsconfig-paths/register src/index.ts",
    "dev": "npx nodemon --exec node -r @swc-node/register -r tsconfig-paths/register src/index.ts dev debug",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "postinstall": "npx prisma generate",
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "arcscord": "0.3.0-beta-8",
    "discord.js": "^14.16.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.11.0",
    "@swc-node/core": "^1.13.3",
    "@swc-node/register": "^1.10.9",
    "@types/node": "^20.16.13",
    "dotenv": "^16.4.5",
    "eslint": "^9.17.0",
    "nodemon": "^3.1.7",
    "prisma": "^7.1.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
